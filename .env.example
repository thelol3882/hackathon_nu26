# =============================================================================
# Locomotive Telemetry — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Infrastructure (TimescaleDB + Redis) ---
POSTGRES_USER=telemetry
POSTGRES_PASSWORD=changeme
POSTGRES_DB=locomotive_telemetry

# --- Processor Service (compute only, no DB) ---
PROCESSOR_REDIS_HOST=redis
PROCESSOR_REDIS_PORT=6379
PROCESSOR_REDIS_DB=0
PROCESSOR_TELEMETRY_BATCH_SIZE=100
PROCESSOR_ALERT_COOLDOWN_SECONDS=30
PROCESSOR_DEBUG=false

# --- DB Writer Service ---
DB_WRITER_DB_HOST=timescaledb
DB_WRITER_DB_PORT=5432
DB_WRITER_DB_USER=telemetry
DB_WRITER_DB_PASSWORD=changeme
DB_WRITER_DB_NAME=locomotive_telemetry
DB_WRITER_DB_POOL_MIN=5
DB_WRITER_DB_POOL_MAX=30
DB_WRITER_REDIS_HOST=redis
DB_WRITER_REDIS_PORT=6379
DB_WRITER_REDIS_DB=0
DB_WRITER_CONSUMER_NAME=writer-1
DB_WRITER_FLUSH_INTERVAL=0.5
DB_WRITER_RETENTION_TELEMETRY_HOURS=72
DB_WRITER_RETENTION_ALERTS_HOURS=168
DB_WRITER_RETENTION_HEALTH_HOURS=168
DB_WRITER_COMPRESSION_AFTER_HOURS=1
DB_WRITER_METRICS_PORT=8004

# --- API Gateway Service ---
GATEWAY_DB_HOST=timescaledb
GATEWAY_DB_PORT=5432
GATEWAY_DB_USER=telemetry
GATEWAY_DB_PASSWORD=changeme
GATEWAY_DB_NAME=locomotive_telemetry
GATEWAY_DB_POOL_MIN=5
GATEWAY_DB_POOL_MAX=20
GATEWAY_REDIS_HOST=redis
GATEWAY_REDIS_PORT=6379
GATEWAY_REDIS_DB=0
GATEWAY_CORS_ORIGINS=["http://localhost:3000"]
GATEWAY_JWT_SECRET=locomotive-telemetry-secret-key-change-in-production
GATEWAY_JWT_EXPIRY_MINUTES=60
GATEWAY_DEBUG=false

# --- Report Service ---
REPORT_DB_HOST=timescaledb
REPORT_DB_PORT=5432
REPORT_DB_USER=telemetry
REPORT_DB_PASSWORD=changeme
REPORT_DB_NAME=locomotive_telemetry
REPORT_DB_POOL_MIN=5
REPORT_DB_POOL_MAX=30
REPORT_REPORT_RETENTION_DAYS=90
REPORT_DEBUG=false

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=locomotive
RABBITMQ_DEFAULT_PASS=changeme
GATEWAY_RABBITMQ_URL=amqp://locomotive:changeme@rabbitmq:5672/
REPORT_RABBITMQ_URL=amqp://locomotive:changeme@rabbitmq:5672/

# --- WebSocket Server ---
WS_SERVER_REDIS_HOST=redis
WS_SERVER_REDIS_PORT=6379
WS_SERVER_REDIS_DB=0
WS_SERVER_MAX_CONNECTIONS=500

# --- Simulator Service ---
SIMULATOR_PROCESSOR_URL=http://processor:8001
SIMULATOR_GATEWAY_URL=http://api-gateway:8000
SIMULATOR_FLEET_SIZE=1700
SIMULATOR_TICK_INTERVAL=1.0
SIMULATOR_BATCH_SIZE=100
SIMULATOR_BURST_MULTIPLIER=1.0
SIMULATOR_SCENARIO=normal
SIMULATOR_SEED=42
SIMULATOR_LOG_LEVEL=INFO

# --- Dashboard (Next.js Frontend) ---
# API and WS URLs auto-detect from browser host in Docker (via nginx proxy).
# Set these only for local dev without Docker (pnpm dev).
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost

# --- Observability (global defaults) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_ENABLED=true
OTEL_TRACE_SAMPLE_RATE=0.05
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Per-service observability overrides (optional) ---
# Prefix: API_GATEWAY_, PROCESSOR_, REPORT_SERVICE_, SIMULATOR_
# Each overrides the global default above for that service only.
#
# SIMULATOR_LOG_LEVEL=WARNING          # Silence simulator logs
# SIMULATOR_OTEL_ENABLED=false         # No traces from simulator
# SIMULATOR_PROMETHEUS_ENABLED=false   # No /metrics on simulator
# SIMULATOR_ACCESS_LOG_ENABLED=false   # No per-request access logs
#
# PROCESSOR_OTEL_ENABLED=false         # Disable processor traces
# PROCESSOR_OTEL_TRACE_SAMPLE_RATE=0.0 # Or just sample 0%
# PROCESSOR_ACCESS_LOG_ENABLED=false   # Suppress noisy ingest logs
#
# REPORT_SERVICE_LOG_LEVEL=DEBUG       # Verbose report-service logs
# API_GATEWAY_LOG_FORMAT=console       # Pretty console logs for gateway
