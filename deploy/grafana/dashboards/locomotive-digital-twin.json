{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Requests per Second",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (service)",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, service))",
          "legendFormat": "{{ service }} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, service))",
          "legendFormat": "{{ service }} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, service))",
          "legendFormat": "{{ service }} p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Telemetry Ingestion Rate",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(telemetry_ingested_total[1m])) by (locomotive_type)",
          "legendFormat": "{{ locomotive_type }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Health Index Calc/s",
      "type": "stat",
      "gridPos": { "h": 7, "w": 4, "x": 8, "y": 7 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(health_index_calculated_total[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Alerts Fired",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "bars",
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(alerts_fired_total[1m])) by (severity)",
          "legendFormat": "{{ severity }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "WebSocket",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "ws_connections_active",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Reports",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 14 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(reports_generated_total)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "In-Progress Requests",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 16, "x": 8, "y": 14 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "http_requests_in_progress",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Errors (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "bars"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[1m])) by (service, status)",
          "legendFormat": "{{ service }} {{ status }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Health Index Distribution",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 5 },
          "unit": "short",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "health_index_value",
          "legendFormat": "{{ locomotive_id }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Service Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 25 },
      "datasource": { "type": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{service=~\".*processor.*\"} | json",
          "legendFormat": "",
          "refId": "A"
        },
        {
          "expr": "{service=~\".*api-gateway.*\"} | json",
          "legendFormat": "",
          "refId": "B"
        },
        {
          "expr": "{service=~\".*report-service.*\"} | json",
          "legendFormat": "",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "datasource": { "type": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service=~\".+\"} | json | level = \"error\" or level = \"critical\"",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Warning Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "datasource": { "type": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service=~\".+\"} | json | level = \"warning\"",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 43 },
      "datasource": { "type": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "drawStyle": "bars",
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\".+\"}[1m])) by (service)",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate (logs)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 43 },
      "datasource": { "type": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "drawStyle": "bars"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\".+\"} | json | level = \"error\"[1m])) by (service)",
          "legendFormat": "{{ service }} errors",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({service=~\".+\"} | json | level = \"warning\"[1m])) by (service)",
          "legendFormat": "{{ service }} warnings",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["locomotive", "telemetry", "digital-twin"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Locomotive Digital Twin",
  "uid": "locomotive-digital-twin",
  "version": 2
}
